<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Exe</OutputType>
        <ImplicitUsings>disable</ImplicitUsings>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <!-- Deliberately depends only on Prowl.Slang: this utility is a raw-Slang baseline generator,
         independent of the Prowl.Graphite.Compiler reflection paths it helps verify. -->
    <ItemGroup>
        <PackageReference Include="Prowl.Slang" Version="0.3.4" />
    </ItemGroup>

</Project>
